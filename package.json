{
  "name": "aquaponics-calculator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "dev": "vite",
    "build:data": "tsx scripts/build-data.ts",
    "prebuild": "pnpm run build:data",
    "build": "tsc --noEmit && vite build",
    "build:single": "pnpm run build:data && tsc --noEmit && BUILD_SINGLEFILE=1 vite build && mv build/index.html build/aquaponics-calculator.html",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^3.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "tinybase": "^8.4.2"
  }
}
